  "description": "Obsidian plugin: Zotero-style PDF reader with highlights, annotations, AI chat, and canvas integration",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "pdf",
    "annotations",
    "highlights",
    "ai",
    "canvas"
  ],
  "author": "voidash",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/voidash/obsidian-pdf-tools.git"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.3.3",
    "wordnet-db": "^3.1.14"
  },
  "dependencies": {
    "nanoid": "^3.3.7",
    "openai": "^6.25.0",
    "pdfjs-dist": "3.11.174"
  }
}
